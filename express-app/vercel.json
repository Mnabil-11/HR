{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server.js,db-helpers.js,config/**,database/**,middleware/**,models/**,routes/**,services/**,utils/**,fonts/**,files/**"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}